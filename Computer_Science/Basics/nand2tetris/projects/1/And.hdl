// File name: projects/1/Not.hdl
/**
 * Not gate:
 * if (in) out = 0, else out = 1
 */
 /* the signal for a and b is same ->
    so "a" and "b" can never be different,
    we eliminated second and thirt row in truth table
 */
CHIP Not {
    IN in;
    OUT out;

    PARTS:
    Nand(a=in , b=in , out=out );
}
