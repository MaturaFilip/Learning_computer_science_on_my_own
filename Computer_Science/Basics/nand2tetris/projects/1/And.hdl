// File name: projects/1/And.hdl
/**
 * And gate:
 * if (a and b) out = 1, else out = 0 
 * We just need to reverse Nand gate
 */
CHIP And {
    IN a, b;
    OUT out;
    
    PARTS:
    // If a = 1 and b = 1 -> Output from Nand is 0. 0 goes to Not gate => result is 1
    Nand(a=a , b=b , out=temp1 );
    Not(in=temp1 , out=out );
}
